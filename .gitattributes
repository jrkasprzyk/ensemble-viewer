# Normalize line endings to LF across all platforms
* text=auto eol=lf

# Explicit text
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.csv  text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.xlsx binary
*.xls  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
